# Required by Azure LLM/STT/TTS
AZURE_API_KEY=

# Use the Azure resource root, for example: https://your-resource-name.openai.azure.com
AZURE_LLM_ENDPOINT=
AZURE_LLM_MODEL=
# For client.py automated testing
AZURE_LLM_SUMMARY_MODEL=

# Required by Azure Speech STT/TTS
AZURE_SPEECH_REGION=
# Voice Gallery: https://speech.microsoft.com/portal/voicegallery
AZURE_SPEECH_VOICE=

# Optional Azure deployment overrides for classifier ensemble models
AZURE_CLASSIFIER_GPT_4_1_MINI_DEPLOYMENT=
AZURE_CLASSIFIER_GPT_5_NANO_DEPLOYMENT=

# Required for LegalServer persistence
LEGAL_SERVER_SUBDOMAIN=
LEGAL_SERVER_BEARER_TOKEN=
LEGALSERVER_TESTING_DISABLE_CONNECTION=

# Required for Dialpad integration
DIALPAD_API_KEY=
DIALPAD_CALL_CENTER_ID=
DIALPAD_SMS_NUMBER=

# Optional logging controls.
LOG_LEVEL=
LOG_TO_FILE=

# Optional runtime tuning.
TRANSFORMERS_NO_ADVISORY_WARNINGS=1

# Optional debugging / observability.
ENABLE_TAIL_RUNNER=
ENABLE_TAIL_OBSERVER=
ENABLE_WHISKER=
TEST_INITIAL_PROMPT=
TEST_INITIAL_FUNCTION=

# str [local, production]
ENV=local
