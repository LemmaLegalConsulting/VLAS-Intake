# Required by Azure LLM/STT/TTS
AZURE_API_KEY=

# Use the Azure resource root, for example: https://your-resource-name.openai.azure.com
AZURE_LLM_ENDPOINT=
AZURE_LLM_MODEL=
# For client.py automated testing
AZURE_LLM_SUMMARY_MODEL=

# Required by Azure Speech STT/TTS
AZURE_SPEECH_REGION=
# Voice Gallery: https://speech.microsoft.com/portal/voicegallery
AZURE_SPEECH_VOICE=

# Optional Azure deployment overrides for classifier ensemble models
AZURE_CLASSIFIER_GPT_4_1_MINI_DEPLOYMENT=
AZURE_CLASSIFIER_GPT_5_NANO_DEPLOYMENT=

# Required for LegalServer persistence
LEGAL_SERVER_SUBDOMAIN=
LEGAL_SERVER_BEARER_TOKEN=
LEGALSERVER_TESTING_DISABLE_CONNECTION=

# Required for Dialpad integration
DIALPAD_API_KEY=
DIALPAD_CALL_CENTER_ID=
DIALPAD_SMS_NUMBER=

# Optional logging controls.
LOG_LEVEL=
LOG_TO_FILE=

# Optional runtime tuning.
TRANSFORMERS_NO_ADVISORY_WARNINGS=1

# Voice Activity Detection (VAD) — controls when the bot considers the user to be speaking.
# confidence: Minimum model confidence [0.0–1.0] to classify a frame as speech. Higher = less sensitive. (default: 0.65)
VAD_CONFIDENCE=
# start_secs: Seconds of continuous speech required before a user turn begins. Higher = fewer false starts. (default: 0.4)
VAD_START_SECS=
# stop_secs: Seconds of silence required after speech ends before the turn closes. Lower = faster response, but may cut off. (default: 0.2)
VAD_STOP_SECS=
# min_volume: Minimum RMS audio volume [0.0–1.0] to be considered speech. Raise this to suppress background noise. (default: 0.55)
VAD_MIN_VOLUME=

# SmartTurn — the ML-based end-of-turn detector that decides when the user is truly done speaking.
# stop_secs: Seconds of post-speech silence before SmartTurn confirms turn end. (default: 4.5)
SMART_TURN_STOP_SECS=
# pre_speech_ms: Milliseconds of audio before speech onset included in the turn analysis window. (default: 700)
SMART_TURN_PRE_SPEECH_MS=
# user_turn_stop_timeout: Hard fallback timeout in seconds — ends the turn even if SmartTurn hasn't fired. (default: 7.0)
USER_TURN_STOP_TIMEOUT_SECS=

# User idle timeout — how long to wait for the user to speak before triggering an idle reminder.
# user_idle_timeout_secs: Base timeout in seconds. (default: 15.0)
USER_IDLE_TIMEOUT_SECS=
# user_idle_timeout_max_secs: Upper bound for the adaptive extension after long assistant turns. (default: max(base, 25.0))
USER_IDLE_TIMEOUT_MAX_SECS=
# user_idle_timeout_words_per_extra_second: Rate at which assistant word count extends the idle timeout. (default: 12.0)
USER_IDLE_TIMEOUT_WORDS_PER_EXTRA_SECOND=

# Optional debugging / observability.
ENABLE_TAIL_RUNNER=
ENABLE_TAIL_OBSERVER=
ENABLE_WHISKER=
TEST_INITIAL_PROMPT=
TEST_INITIAL_FUNCTION=

# str [local, production]
ENV=local
